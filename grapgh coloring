# ==========================================
# GRAPH COLORING USING GREEDY ALGORITHM
# ==========================================


# Adjacency Matrix of graph
# 1 means connection (edge exists)
# 0 means no connection
G = [

    # a  b  c  d  e  f
    [0, 1, 1, 0, 1, 0],  # a
    [1, 0, 1, 1, 0, 1],  # b
    [1, 1, 0, 1, 1, 0],  # c
    [0, 1, 1, 0, 0, 1],  # d
    [1, 0, 1, 0, 0, 1],  # e
    [0, 1, 0, 1, 1, 0]   # f
]


# Names of vertices
# index 0 = a
# index 1 = b
# index 2 = c
# index 3 = d
# index 4 = e
# index 5 = f
node = "abcdef"


# Available colors
colors = ["Blue", "Red", "Yellow", "Green"]


# Dictionary to store final answer
# Example:
# {'a':'Blue'}
solution = {}


# ==========================================
# CHECK EACH NODE ONE BY ONE
# ==========================================
for i in range(len(G)):


    # Store colors already used
    # by neighboring vertices
    used = []


    # Check all neighbors
    for j in range(len(G)):


        # If edge exists AND neighbor is already colored
        if G[i][j] == 1 and node[j] in solution:


            # Store neighbor color
            used.append(solution[node[j]])


    # Try colors one by one
    for color in colors:


        # If color not used by neighbors
        if color not in used:


            # Assign color
            solution[node[i]] = color


            # Stop checking more colors
            break


# ==========================================
# PRINT FINAL SOLUTION
# ==========================================
for n in solution:

    print("Node", n, "=", solution[n])



